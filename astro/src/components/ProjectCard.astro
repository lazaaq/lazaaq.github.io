---
// src/components/ProjectCard.astro
import type { Project } from '@/data/projects';
import { DIFFICULTY_LABEL, DIFFICULTY_DOTS } from '@/data/projects';

interface Props {
  project: Project;
  index: number;
}

const { project: p, index } = Astro.props;
const dots = DIFFICULTY_DOTS[p.difficulty];
const label = DIFFICULTY_LABEL[p.difficulty];
---

<article
  class="project-card"
  data-cat={p.category}
  data-tags={[...p.primaryTags, ...p.tags].join(',')}
  data-difficulty={p.difficulty}
  data-year={p.year}
  style={`animation-delay: ${index * 0.06}s`}
>
  <!-- Thumbnail -->
  <div class="thumb">
    {p.thumbnail
      ? <img src={p.thumbnail} alt={p.title} loading="lazy" />
      : (
        <div class="thumb-fallback">
          <span class="thumb-icon">{p.thumbIcon}</span>
        </div>
      )
    }

    <div class:list={['diff-badge', p.difficulty]}>
      <span class="diff-dots">
        {Array.from({ length: 4 }, (_, i) => (
          <span class:list={['dd', { filled: i < dots }]}></span>
        ))}
      </span>
      {label}
    </div>
  </div>

  <!-- Body -->
  <div class="body">
    <p class="num">{p.num}</p>
    <h3 class="title">{p.title}</h3>
    <p class="desc">{p.desc}</p>
    <div class="tags">
      {p.primaryTags.map(t => <span class="tag tag-primary">{t}</span>)}
      {p.tags.map(t => <span class="tag">{t}</span>)}
    </div>
  </div>

  <!-- Footer -->
  <footer class="card-foot">
    <span class:list={['diff-label', p.difficulty]}>
      <span class="diff-dots">
        {Array.from({ length: 4 }, (_, i) => (
          <span class:list={['dd', { filled: i < dots }]}></span>
        ))}
      </span>
      {label}
    </span>
    <div class="links">
      {p.links.map(l => (
        <a href={l.url} class="card-link" target="_blank" rel="noopener">{l.label}</a>
      ))}
    </div>
  </footer>
</article>

<style>
  /* ── Base card ── */
  .project-card {
    background: var(--bg);
    display: flex;
    flex-direction: column;
    transition: background .2s;
    animation: fadeUp .5s ease both;
  }

  .project-card:hover { background: var(--surface); }

  /* ── Thumbnail ── */
  .thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
    background: #111;
    flex-shrink: 0;
  }

  .thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.85);
    transition: transform .4s ease, filter .3s;
  }

  .project-card:hover .thumb img {
    transform: scale(1.04);
    filter: brightness(1);
  }

  .thumb-fallback {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #111 0%, #161616 100%);
  }

  .thumb-icon { font-size: 3rem; opacity: .5; }

  /* ── Difficulty badge ── */
  .diff-badge {
    position: absolute; top: .75rem; right: .75rem;
    font-family: var(--font-mono);
    font-size: .6rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .3rem .75rem;
    display: flex; align-items: center; gap: .4rem;
    z-index: 2;
  }

  .diff-badge.easy   { background: rgba(92,184,92,.15);  color: var(--diff-easy);   border: 1px solid rgba(92,184,92,.3);  }
  .diff-badge.medium { background: rgba(240,173,78,.15); color: var(--diff-medium); border: 1px solid rgba(240,173,78,.3); }
  .diff-badge.hard   { background: rgba(217,83,79,.15);  color: var(--diff-hard);   border: 1px solid rgba(217,83,79,.3);  }
  .diff-badge.expert { background: rgba(155,89,182,.15); color: var(--diff-expert); border: 1px solid rgba(155,89,182,.3); }

  /* ── Dots ── */
  .diff-dots { display: flex; gap: 3px; }

  .dd {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: currentColor;
    opacity: .3;
  }

  .dd.filled { opacity: 1; }

  /* ── Body ── */
  .body {
    padding: 1.5rem 1.75rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .num {
    font-family: var(--font-mono);
    font-size: .6rem;
    color: var(--accent2);
    letter-spacing: .14em;
    margin-bottom: .5rem;
  }

  .title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: .6rem;
    line-height: 1.2;
  }

  .desc {
    font-size: .82rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .tags { display: flex; flex-wrap: wrap; gap: .4rem; }

  /* ── Card footer ── */
  .card-foot {
    padding: 1rem 1.75rem;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0;
  }

  .diff-label {
    font-family: var(--font-mono);
    font-size: .65rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    display: flex; align-items: center; gap: .5rem;
  }

  .diff-label.easy   { color: var(--diff-easy); }
  .diff-label.medium { color: var(--diff-medium); }
  .diff-label.hard   { color: var(--diff-hard); }
  .diff-label.expert { color: var(--diff-expert); }

  .links { display: flex; gap: .6rem; }

  .card-link {
    font-family: var(--font-mono);
    font-size: .65rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: .08em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    padding: .3rem .75rem;
    transition: color .2s, border-color .2s;
  }

  .card-link:hover { color: var(--accent); border-color: var(--accent); }
</style>