---
import "@/styles/global.css";
import { COMPANY } from "@/data/company-profile";
import { projects } from "@/data/projects";

const categoryLabels = {
    web: "Aplikasi Web",
    backend: "Backend",
    mobile: "Aplikasi Mobile",
    oss: "Open Source",
    ml: "Machine Learning",
    cms: "CMS",
    ecommerce: "E-Commerce",
    landing: "Landing Page",
};

const difficultyLabels = {
    easy: "Mudah",
    medium: "Menengah",
    hard: "Sulit",
    expert: "Expert",
};

const excludedProjectIds = new Set(["kofee", "rpkps", "livelihood", "expice"]);

const filteredProjects = projects.filter(
    (project) => !excludedProjectIds.has(project.id),
);

const sortedProjects = [...filteredProjects].sort((a, b) => {
    if (b.year !== a.year) return b.year - a.year;
    return Number(a.num) - Number(b.num);
});

const totalProjects = sortedProjects.length;
const yearRange = `${sortedProjects[sortedProjects.length - 1]?.year} - ${sortedProjects[0]?.year}`;
const projectCategories = [...new Set(sortedProjects.map((project) => categoryLabels[project.category]))];
const whatsappNumber = COMPANY.phone.replaceAll(/\D/g, "");
const whatsappHref = `https://wa.me/${whatsappNumber}`;
const mapLinkLabel = (label) => (label === "↗ Live" ? "↗ Lihat" : label);
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta
            name="description"
            content={`${COMPANY.name} membantu perusahaan membangun website company profile yang rapi, terpercaya, dan siap berkembang.`}
        />
        <title>{COMPANY.name} — Profil Perusahaan</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    </head>
    <body>
        <main class="company-page">
            <section class="hero-shell">
                <header class="topbar">
                    <a href="/company-profile" class="brand">
                        <img
                            src="/images/webister-logo.png"
                            alt={`${COMPANY.name} logo`}
                            class="brand-logo"
                        />
                        <span>
                            <strong>{COMPANY.name}</strong>
                            <small>{COMPANY.tag}</small>
                        </span>
                    </a>

                    <nav class="hero-nav" aria-label="Navigasi profil perusahaan">
                        <a href="#expertise">Keahlian</a>
                        <a href="#projects">Proyek</a>
                        <a href="#contact">Kontak</a>
                    </nav>
                </header>

                <div class="hero-grid">
                    <div class="hero-copy">
                        <p class="section-label">Profil Perusahaan</p>
                        <h1>{COMPANY.tagline}</h1>
                        <p class="hero-desc">{COMPANY.description}</p>

                        <div class="hero-actions">
                            <a class="btn btn-primary" href={COMPANY.heroPrimaryCta.href}>
                                {COMPANY.heroPrimaryCta.label}
                            </a>
                            <a class="btn btn-ghost" href={COMPANY.heroSecondaryCta.href}>
                                {COMPANY.heroSecondaryCta.label}
                            </a>
                        </div>

                        <ul class="hero-points">
                            {COMPANY.introPoints.map((point) => <li>{point}</li>)}
                        </ul>
                    </div>

                    <aside class="hero-panel">
                        <div class="logo-card">
                            <img
                                src="/images/webister-logo.png"
                                alt={`${COMPANY.name} logo`}
                                class="hero-logo"
                            />
                        </div>

                        <div class="signal-card">
                            <span class="signal-label">Posisi</span>
                            <h2>Dibangun untuk perusahaan yang menginginkan kehadiran digital yang lebih sederhana, bersih, dan terpercaya.</h2>
                            <p>
                                Arah visual halaman ini mengikuti identitas Webister: biru terang,
                                permukaan putih yang lembut, dan antarmuka yang terasa tenang,
                                mudah diakses, dan meyakinkan.
                            </p>
                        </div>

                        <div class="contact-card">
                            <div>
                                <span class="signal-label">Lokasi</span>
                                <p>{COMPANY.location}</p>
                            </div>
                            <div>
                                <span class="signal-label">Email</span>
                                <p>{COMPANY.email}</p>
                            </div>
                            <div>
                                <span class="signal-label">Phone</span>
                                <p>{COMPANY.phone}</p>
                            </div>
                        </div>
                    </aside>
                </div>
            </section>

            <section class="stats-band">
                {COMPANY.stats.map((stat) => (
                    <article class="stat-card">
                        <strong>
                            {stat.label === "Proyek Selesai" ? totalProjects : stat.value}
                        </strong>
                        <span>{stat.label}</span>
                    </article>
                ))}
            </section>

            <section id="expertise" class="content-section">
                <div class="section-head">
                    <p class="section-label">Apa yang Kami Kerjakan</p>
                    <h2>Ringkasan singkat tentang apa yang dibangun Webister, siapa yang kami layani, dan bagaimana proses pengerjaannya berjalan.</h2>
                </div>

                <div class="expertise-grid">
                    <article class="summary-card">
                        <span class="signal-label">Layanan Utama</span>
                        <div class="summary-list">
                            {COMPANY.services.map((service) => (
                                <div class="summary-item">
                                    <h3>{service.title}</h3>
                                    <p>{service.blurb}</p>
                                </div>
                            ))}
                        </div>
                    </article>

                    <article class="summary-card">
                        <span class="signal-label">Cocok Untuk</span>
                        <h3>Paling relevan untuk bisnis yang membutuhkan kehadiran online yang lebih jelas dan website perusahaan yang lebih profesional.</h3>
                        <p class="summary-copy">
                            Webister sangat cocok untuk tim yang menginginkan alur kerja yang
                            sederhana, struktur yang lebih baik, dan website yang lebih mudah
                            dipercaya serta lebih mudah dihubungi.
                        </p>
                        <div class="compact-chip-list">
                            {COMPANY.sectors.map((sector) => <span>{sector}</span>)}
                        </div>
                    </article>

                    <article class="summary-card">
                        <span class="signal-label">Cara Kami Bekerja</span>
                        <div class="compact-flow">
                            {COMPANY.process.map((item) => (
                                <div class="flow-item">
                                    <strong>{item.step}</strong>
                                    <div>
                                        <h4>{item.title}</h4>
                                        <p>{item.desc}</p>
                                    </div>
                                </div>
                            ))}
                        </div>
                        <div class="compact-chip-list compact-chip-list-muted">
                            {COMPANY.capabilities.slice(0, 6).map((item) => <span>{item}</span>)}
                        </div>
                    </article>
                </div>
            </section>

            <section id="projects" class="content-section project-section">
                <div class="section-head">
                    <p class="section-label">Showcase Proyek</p>
                    <h2>Semua proyek portfolio kini ditampilkan di sini sebagai bukti eksekusi lintas industri dan berbagai format pekerjaan.</h2>
                </div>

                <div class="project-overview">
                    <article class="project-overview-card">
                        <span class="signal-label">Cakupan Portfolio</span>
                        <strong>{totalProjects} Proyek</strong>
                        <p>Ditampilkan langsung dari sumber data portfolio yang sama, sehingga judul, deskripsi, stack, dan link tetap konsisten.</p>
                    </article>

                    <article class="project-overview-card">
                        <span class="signal-label">Rentang Waktu</span>
                        <strong>{yearRange}</strong>
                        <p>Dari landing page dan company profile awal hingga sistem internal, machine learning, dan platform berbasis data.</p>
                    </article>

                    <article class="project-overview-card">
                        <span class="signal-label">Kategori</span>
                        <strong>{projectCategories.length} Jenis</strong>
                        <p>{projectCategories.join(" • ")}</p>
                    </article>
                </div>

                <div class="project-grid">
                    {sortedProjects.map((project) => (
                        <article class="project-showcase-card">
                            <div class="project-card-head">
                                <div class="project-symbol">
                                    {project.thumbnail ? (
                                        <img src={project.thumbnail} alt={project.title} />
                                    ) : (
                                        <span>{project.thumbIcon}</span>
                                    )}
                                </div>

                                <div class="project-head-copy">
                                    <div class="project-topline">
                                        <span class="project-num">Proyek {project.num}</span>
                                        <span class="project-year">{project.year}</span>
                                    </div>
                                    <h3>{project.title}</h3>
                                </div>
                            </div>

                            <div class="project-meta-row">
                                <span class="meta-pill meta-pill-primary">
                                    {categoryLabels[project.category]}
                                </span>
                                <span class="meta-pill">
                                    {difficultyLabels[project.difficulty]}
                                </span>
                            </div>

                            <p class="project-card-desc">{project.desc}</p>

                            <div class="project-tag-group">
                                {project.primaryTags.map((tag) => (
                                    <span class="project-tag project-tag-primary">{tag}</span>
                                ))}
                                {project.tags.map((tag) => (
                                    <span class="project-tag">{tag}</span>
                                ))}
                            </div>

                            {project.links.length > 0 && (
                                <div class="project-link-row">
                                    {project.links.map((link) => (
                                        <a href={link.url} class="project-link" target="_blank" rel="noopener">
                                            {mapLinkLabel(link.label)}
                                        </a>
                                    ))}
                                </div>
                            )}
                        </article>
                    ))}
                </div>
            </section>

            <section class="quote-section">
                <blockquote>
                    “{COMPANY.quote.text}”
                </blockquote>
                <p>{COMPANY.quote.author} · {COMPANY.quote.role}</p>
            </section>

            <section class="content-section faq-section">
                <div class="section-head">
                    <p class="section-label">FAQ</p>
                    <h2>Jawaban singkat untuk tim yang sedang mencari partner digital yang tepat.</h2>
                </div>

                <div class="faq-list">
                    {COMPANY.faq.map((item) => (
                        <article class="faq-item">
                            <h3>{item.q}</h3>
                            <p>{item.a}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section id="contact" class="cta-section">
                <div class="cta-copy">
                    <p class="section-label">Mulai Proyek</p>
                    <h2>Butuh website perusahaan yang terlihat kredibel dan lebih mudah dipercaya?</h2>
                    <p class="cta-body">
                        Biarkan Webister merancang struktur, kejelasan visual, dan alur kontaknya
                        lebih dulu, lalu mengubahnya menjadi website yang rapi dan siap mewakili
                        bisnis Anda dengan baik.
                    </p>
                </div>

                <div class="cta-panel">
                    <p class="cta-panel-kicker">Hubungi Webister</p>
                    <div class="cta-actions">
                        <a class="btn btn-primary" href={`mailto:${COMPANY.email}`}>
                            {COMPANY.email}
                        </a>
                        <a class="btn btn-ghost" href={`tel:${COMPANY.phone.replaceAll(" ", "")}`}>
                            {COMPANY.phone}
                        </a>
                    </div>
                    <p class="cta-note">
                        Cocok untuk website company profile, landing page, dan peningkatan
                        presentasi digital bagi bisnis yang sedang berkembang.
                    </p>
                </div>
            </section>

            <a
                href={whatsappHref}
                class="whatsapp-float"
                target="_blank"
                rel="noopener"
                aria-label="Chat dengan Webister di WhatsApp"
            >
                <span class="whatsapp-icon">W</span>
                <span class="whatsapp-text">WhatsApp</span>
            </a>
        </main>
    </body>
</html>

<style>
    .company-page {
        --bg: #f6f9ff;
        --surface: #ffffff;
        --border: rgba(78, 116, 244, 0.14);
        --accent: #4772f3;
        --accent2: #7ea2ff;
        --text: #111111;
        --muted: #222222;
        --brand-blue: #4772f3;
        --brand-blue-deep: #2f5de5;
        --brand-blue-soft: #edf3ff;
        --brand-blue-tint: #dce8ff;
        --brand-shadow: rgba(71, 114, 243, 0.14);
    }

    .company-page h1,
    .company-page h2,
    .company-page h3,
    .company-page strong,
    .company-page blockquote {
        color: var(--text);
    }

    .company-page .section-label {
        font-size: 0.92rem;
        letter-spacing: 0.16em;
        margin-bottom: 1rem;
    }

    :global(body) {
        background:
            radial-gradient(circle at 16% 14%, rgba(71, 114, 243, 0.12), transparent 26%),
            radial-gradient(circle at 82% 18%, rgba(126, 162, 255, 0.16), transparent 24%),
            linear-gradient(180deg, #f9fbff 0%, #f2f7ff 46%, #eef4ff 100%);
    }

    :global(body::after) {
        opacity: 0.18;
    }

    .company-page {
        padding: clamp(1.25rem, 3.8vw, 4rem);
    }

    .hero-shell,
    .content-section,
    .quote-section,
    .cta-section,
    .stats-band {
        width: 100%;
        margin: 0 auto;
    }

    .hero-shell {
        min-height: calc(100vh - 3rem);
        padding: 1.25rem;
        border: 1px solid var(--border);
        border-radius: 32px;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 248, 255, 0.98));
        box-shadow: 0 28px 80px var(--brand-shadow);
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.35rem 0.35rem 0;
    }

    .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
        color: var(--text);
        text-decoration: none;
    }

    .brand strong {
        display: block;
        font-size: 1rem;
        font-weight: 600;
    }

    .brand small {
        display: block;
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 0.65rem;
        margin-top: 0.15rem;
    }

    .brand-logo {
        width: 120px;
        height: auto;
        display: block;
    }

    .hero-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 1.25rem;
    }

    .hero-nav a {
        color: var(--muted);
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 0.86rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .hero-nav a:hover {
        color: var(--accent);
    }

    .hero-grid {
        flex: 1;
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.7fr);
        gap: 1.5rem;
        align-items: stretch;
    }

    .hero-copy,
    .hero-panel {
        border-radius: 28px;
        overflow: hidden;
    }

    .hero-copy {
        padding: clamp(2rem, 5vw, 4rem);
        background:
            radial-gradient(circle at top left, rgba(71, 114, 243, 0.08), transparent 34%),
            linear-gradient(180deg, #ffffff, #f6f9ff);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .hero-copy h1 {
        font-family: var(--font-serif);
        font-size: clamp(3.1rem, 7vw, 6.3rem);
        line-height: 0.98;
        max-width: 10.5ch;
        margin-bottom: 1.25rem;
    }

    .hero-desc {
        color: var(--muted);
        font-size: 1.03rem;
        max-width: 58ch;
        line-height: 1.9;
        margin-bottom: 1.75rem;
    }

    .hero-copy :global(.btn-primary) {
        background: var(--brand-blue);
        border-color: var(--brand-blue);
        color: white;
    }

    .hero-copy :global(.btn-primary:hover) {
        background: var(--brand-blue-deep);
        border-color: var(--brand-blue-deep);
    }

    .hero-copy :global(.btn-ghost) {
        color: var(--brand-blue);
        border-color: rgba(71, 114, 243, 0.18);
        background: rgba(255, 255, 255, 0.75);
    }

    .hero-copy :global(.btn-ghost:hover) {
        border-color: var(--brand-blue);
        background: var(--brand-blue-soft);
    }

    .hero-actions {
        display: flex;
        gap: 0.9rem;
        flex-wrap: wrap;
        margin-bottom: 1.75rem;
    }

    .hero-points {
        display: grid;
        gap: 0.8rem;
        list-style: none;
        max-width: 54ch;
    }

    .hero-points li {
        padding: 0.95rem 1rem;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(71, 114, 243, 0.12);
        color: var(--text);
        box-shadow: 0 10px 24px rgba(71, 114, 243, 0.06);
    }

    .hero-panel {
        display: grid;
        gap: 1rem;
    }

    .logo-card,
    .signal-card,
    .contact-card {
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 18px 44px rgba(71, 114, 243, 0.08);
    }

    .logo-card {
        padding: 1.6rem;
        border-radius: 24px;
        border: 1px solid var(--border);
        display: grid;
        place-items: center;
        min-height: 210px;
        background:
            radial-gradient(circle at top, rgba(71, 114, 243, 0.08), transparent 38%),
            linear-gradient(180deg, #ffffff, #f4f8ff);
    }

    .hero-logo {
        width: min(280px, 100%);
        height: auto;
        display: block;
        mix-blend-mode: multiply;
    }

    .signal-card,
    .contact-card {
        padding: 1.4rem;
        border-radius: 24px;
        border: 1px solid var(--border);
    }

    .signal-card {
        min-height: 54%;
        background:
            radial-gradient(circle at top left, rgba(71, 114, 243, 0.14), transparent 42%),
            linear-gradient(180deg, #ffffff, #f3f7ff);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .signal-card h2,
    .sector-panel h2,
    .capability-panel h2,
    .cta-section h2,
    .section-head h2 {
        font-family: var(--font-serif);
        font-size: clamp(2rem, 4.4vw, 3.3rem);
        line-height: 1.04;
        font-weight: 400;
    }

    .signal-card p,
    .contact-card p,
    .service-card p,
    .featured-card p,
    .faq-item p,
    .cta-section p,
    .process-card p {
        color: var(--muted);
        line-height: 1.8;
    }

    .contact-card {
        display: grid;
        gap: 1rem;
    }

    .signal-label {
        display: inline-block;
        margin-bottom: 0.6rem;
        color: var(--accent);
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
    }

    .stats-band {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        padding: 1rem 0 0;
    }

    .stat-card {
        padding: 1.2rem;
        border-radius: 22px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.88);
        display: grid;
        gap: 0.3rem;
        box-shadow: 0 18px 36px rgba(71, 114, 243, 0.06);
    }

    .stat-card strong {
        font-family: var(--font-serif);
        font-size: clamp(1.9rem, 4vw, 3rem);
        font-weight: 400;
    }

    .stat-card span {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
    }

    .content-section,
    .quote-section,
    .cta-section {
        margin-top: 1rem;
        padding: clamp(1.4rem, 3vw, 2rem);
        border-radius: 28px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(245, 249, 255, 0.98));
        box-shadow: 0 20px 48px rgba(71, 114, 243, 0.06);
    }

    .section-head {
        display: flex;
        justify-content: space-between;
        gap: 2rem;
        align-items: end;
        margin-bottom: 1.4rem;
    }

    .section-head h2 {
        max-width: 16ch;
    }

    .service-grid,
    .faq-list,
    .process-grid,
    .project-grid,
    .project-overview,
    .expertise-grid {
        display: grid;
        gap: 1rem;
    }

    .expertise-grid {
        grid-template-columns: 1.1fr 0.9fr 1fr;
    }

    .summary-card {
        padding: 1.4rem;
        border-radius: 22px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(239, 245, 255, 0.96));
        box-shadow: 0 18px 38px rgba(71, 114, 243, 0.08);
    }

    .summary-list {
        display: grid;
        gap: 1rem;
    }

    .summary-item {
        padding-top: 0.9rem;
        border-top: 1px solid rgba(71, 114, 243, 0.1);
    }

    .summary-item:first-child {
        padding-top: 0;
        border-top: 0;
    }

    .summary-item h3,
    .summary-card h3,
    .flow-item h4 {
        margin-bottom: 0.45rem;
        color: var(--text);
    }

    .summary-item p,
    .summary-copy,
    .flow-item p {
        color: var(--muted);
        line-height: 1.8;
    }

    .summary-copy {
        margin: 0.75rem 0 1rem;
    }

    .compact-chip-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1rem;
    }

    .compact-chip-list span {
        padding: 0.55rem 0.75rem;
        border-radius: 999px;
        border: 1px solid rgba(71, 114, 243, 0.14);
        background: var(--brand-blue-soft);
        color: var(--brand-blue-deep);
        font-family: var(--font-mono);
        font-size: 0.66rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .compact-chip-list-muted span {
        background: rgba(255, 255, 255, 0.92);
        color: var(--text);
    }

    .compact-flow {
        display: grid;
        gap: 0.9rem;
    }

    .flow-item {
        display: grid;
        grid-template-columns: 54px 1fr;
        gap: 0.8rem;
        align-items: start;
        padding-top: 0.9rem;
        border-top: 1px solid rgba(71, 114, 243, 0.1);
    }

    .flow-item:first-child {
        padding-top: 0;
        border-top: 0;
    }

    .flow-item strong {
        display: inline-flex;
        justify-content: center;
        padding: 0.45rem 0.5rem;
        border-radius: 999px;
        background: var(--brand-blue);
        color: white;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
    }

    .flow-item h4 {
        font-size: 1rem;
        font-weight: 600;
    }

    .service-grid {
        grid-template-columns: repeat(3, 1fr);
    }

